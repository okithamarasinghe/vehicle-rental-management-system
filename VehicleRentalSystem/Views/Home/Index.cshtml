@model VehicleRentalSystem.ViewModels.DashboardViewModel
@{
    ViewData["Title"]            = "Dashboard";
    ViewData["BreadcrumbCurrent"] = "Dashboard";
}

<!-- ── KPI Cards ──────────────────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 kpi-card kpi-primary">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="kpi-icon bg-primary text-white">
                    <i class="bi bi-car-front fs-3"></i>
                </div>
                <div>
                    <div class="kpi-value">@Model.TotalVehicles</div>
                    <div class="kpi-label">Total Vehicles</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 kpi-card kpi-success">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="kpi-icon bg-success text-white">
                    <i class="bi bi-check-circle fs-3"></i>
                </div>
                <div>
                    <div class="kpi-value">@Model.AvailableVehicles</div>
                    <div class="kpi-label">Available</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 kpi-card kpi-warning">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="kpi-icon bg-warning text-white">
                    <i class="bi bi-calendar-check fs-3"></i>
                </div>
                <div>
                    <div class="kpi-value">@Model.ReservedVehicles</div>
                    <div class="kpi-label">Reserved</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 kpi-card kpi-danger">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="kpi-icon bg-danger text-white">
                    <i class="bi bi-tools fs-3"></i>
                </div>
                <div>
                    <div class="kpi-value">@Model.MaintenanceVehicles</div>
                    <div class="kpi-label">Maintenance</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 kpi-card">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="kpi-icon bg-info text-white">
                    <i class="bi bi-people fs-3"></i>
                </div>
                <div>
                    <div class="kpi-value">@Model.TotalCustomers</div>
                    <div class="kpi-label">Customers</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 kpi-card">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="kpi-icon bg-secondary text-white">
                    <i class="bi bi-geo-alt fs-3"></i>
                </div>
                <div>
                    <div class="kpi-value">@Model.TotalLocations</div>
                    <div class="kpi-label">Locations</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 kpi-card kpi-success">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="kpi-icon bg-success text-white">
                    <i class="bi bi-cash-coin fs-3"></i>
                </div>
                <div>
                    <div class="kpi-value">LKR @Model.TotalRevenue.ToString("N0")</div>
                    <div class="kpi-label">Total Revenue</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 kpi-card kpi-primary">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="kpi-icon bg-primary text-white">
                    <i class="bi bi-graph-up-arrow fs-3"></i>
                </div>
                <div>
                    <div class="kpi-value">LKR @Model.MonthRevenue.ToString("N0")</div>
                    <div class="kpi-label">This Month</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Charts ─────────────────────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-12 col-xl-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-bar-chart me-2 text-primary"></i>Monthly Revenue (LKR)</h6>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" height="100"></canvas>
            </div>
        </div>
    </div>
    <div class="col-12 col-xl-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-pie-chart me-2 text-success"></i>Vehicles by Location</h6>
            </div>
            <div class="card-body">
                <canvas id="locationChart" height="180"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-xl-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-activity me-2 text-warning"></i>Monthly Reservations</h6>
            </div>
            <div class="card-body">
                <canvas id="reservationChart" height="130"></canvas>
            </div>
        </div>
    </div>
    <div class="col-12 col-xl-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0"><i class="bi bi-clock-history me-2 text-info"></i>Recent Reservations</h6>
                <a asp-controller="Reservation" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#ID</th>
                                <th>Customer</th>
                                <th>Vehicle</th>
                                <th>Start</th>
                                <th>Status</th>
                                <th>Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.RecentReservations)
                            {
                                <tr>
                                    <td><a asp-controller="Reservation" asp-action="Details" asp-route-id="@r.ReservationID" class="fw-bold">#@r.ReservationID</a></td>
                                    <td>
                                        <div class="fw-semibold">@r.CustomerName</div>
                                        <small class="text-muted">@r.CustomerNIC</small>
                                    </td>
                                    <td>
                                        <div>@r.VehicleDetails</div>
                                        <small class="text-muted">@r.PlateNumber</small>
                                    </td>
                                    <td><small>@r.StartDate.ToString("dd MMM yyyy")</small></td>
                                    <td>
                                        @{
                                            var badgeClass = r.Payment switch
                                            {
                                                VehicleRentalSystem.Models.PaymentStatus.Paid     => "bg-success",
                                                VehicleRentalSystem.Models.PaymentStatus.Refunded => "bg-secondary",
                                                _                                                  => "bg-warning text-dark"
                                            };
                                        }
                                        <span class="badge @badgeClass">@r.Payment</span>
                                    </td>
                                    <td class="fw-semibold">@r.Price.ToString("N0")</td>
                                </tr>
                            }
                            @if (!Model.RecentReservations.Any())
                            {
                                <tr><td colspan="6" class="text-center text-muted py-3">No reservations yet</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// Revenue Chart
const revenueLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenue.Select(m => m.Label)));
const revenueData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenue.Select(m => m.Value)));
new Chart(document.getElementById('revenueChart'), {
    type: 'bar',
    data: {
        labels: revenueLabels,
        datasets: [{
            label: 'Revenue (LKR)',
            data: revenueData,
            backgroundColor: 'rgba(13,110,253,0.7)',
            borderColor: 'rgb(13,110,253)',
            borderWidth: 1,
            borderRadius: 4
        }]
    },
    options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
});

// Location Pie Chart
const locLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LocationBreakdown.Select(l => l.Location)));
const locData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LocationBreakdown.Select(l => l.Count)));
new Chart(document.getElementById('locationChart'), {
    type: 'doughnut',
    data: {
        labels: locLabels,
        datasets: [{ data: locData, backgroundColor: ['#0d6efd','#198754','#ffc107','#dc3545','#0dcaf0','#6f42c1'] }]
    },
    options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
});

// Reservation Count Chart
const resLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyCount.Select(m => m.Label)));
const resData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyCount.Select(m => m.Value)));
new Chart(document.getElementById('reservationChart'), {
    type: 'line',
    data: {
        labels: resLabels,
        datasets: [{
            label: 'Reservations',
            data: resData,
            borderColor: 'rgb(255,193,7)',
            backgroundColor: 'rgba(255,193,7,0.1)',
            tension: 0.3,
            fill: true
        }]
    },
    options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
});
</script>
}
