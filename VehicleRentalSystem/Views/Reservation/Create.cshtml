@model VehicleRentalSystem.ViewModels.ReservationViewModel
@using VehicleRentalSystem.Models
@{
    ViewData["Title"]             = "New Reservation";
    ViewData["BreadcrumbParent"]  = "Reservations";
    ViewData["BreadcrumbCurrent"] = "Create";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h5 class="fw-bold"><i class="bi bi-calendar-plus me-2 text-success"></i>Create New Reservation</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" id="reservationForm">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="row g-3">
                        <!-- Customer -->
                        <div class="col-md-6">
                            <label asp-for="CustomerNIC" class="form-label fw-semibold"></label>
                            <select asp-for="CustomerNIC" class="form-select" required>
                                <option value="">– Select Customer –</option>
                                @foreach (var c in Model.Customers)
                                {
                                    <option value="@c.NIC" selected="@(Model.CustomerNIC == c.NIC)">
                                        @c.Name (@c.NIC)
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="CustomerNIC" class="text-danger small"></span>
                        </div>

                        <!-- Vehicle -->
                        <div class="col-md-6">
                            <label asp-for="PlateNumber" class="form-label fw-semibold">
                                Vehicle (Available Only)
                            </label>
                            <select asp-for="PlateNumber" class="form-select" id="vehicleSelect" required>
                                <option value="">– Select Vehicle –</option>
                                @foreach (var v in Model.Vehicles)
                                {
                                    <option value="@v.PlateNumber"
                                            data-rate="@v.DailyRate"
                                            selected="@(Model.PlateNumber == v.PlateNumber)">
                                        @v.PlateNumber – @v.Manufacturer @v.Model (@v.Year) – LKR @v.DailyRate.ToString("N0")/day
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="PlateNumber" class="text-danger small"></span>
                        </div>

                        <!-- Dates -->
                        <div class="col-md-4">
                            <label asp-for="RentalStartDate" class="form-label fw-semibold"></label>
                            <input asp-for="RentalStartDate" type="date" class="form-control"
                                   id="startDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="RentalStartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="RentalEndDate" class="form-label fw-semibold"></label>
                            <input asp-for="RentalEndDate" type="date" class="form-control"
                                   id="endDate" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="RentalEndDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Rental Duration</label>
                            <div class="form-control bg-light fw-bold" id="daysDisplay">– days</div>
                        </div>

                        <!-- Price -->
                        <div class="col-md-4">
                            <label asp-for="Price" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">LKR</span>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" id="priceInput" />
                            </div>
                            <small class="text-muted">Auto-calculated. Override if needed.</small>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PaymentStatus" class="form-label fw-semibold"></label>
                            <select asp-for="PaymentStatus" class="form-select">
                                @foreach (PaymentStatus ps in Enum.GetValues(typeof(PaymentStatus)))
                                {
                                    <option value="@((int)ps)">@ps</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Estimated Total</label>
                            <div class="form-control bg-success text-white fw-bold" id="totalDisplay">LKR 0</div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label fw-semibold"></label>
                            <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Optional notes"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-check-circle me-1"></i>Create Reservation
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
function recalc() {
    const start = document.getElementById('startDate').value;
    const end   = document.getElementById('endDate').value;
    const sel   = document.getElementById('vehicleSelect');
    const rate  = parseFloat(sel.options[sel.selectedIndex]?.dataset?.rate || 0);

    if (start && end && start < end) {
        const days  = Math.round((new Date(end) - new Date(start)) / 86400000);
        const total = days * rate;
        document.getElementById('daysDisplay').textContent = `${days} day(s)`;
        document.getElementById('priceInput').value = total.toFixed(2);
        document.getElementById('totalDisplay').textContent = `LKR ${total.toLocaleString()}`;
    } else {
        document.getElementById('daysDisplay').textContent = '– days';
        document.getElementById('totalDisplay').textContent = 'LKR 0';
    }
}
document.getElementById('startDate').addEventListener('change', recalc);
document.getElementById('endDate').addEventListener('change', recalc);
document.getElementById('vehicleSelect').addEventListener('change', recalc);
recalc();
</script>
}
