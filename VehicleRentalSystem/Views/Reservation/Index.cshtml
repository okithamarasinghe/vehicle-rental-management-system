@model VehicleRentalSystem.ViewModels.ReservationSearchViewModel
@using VehicleRentalSystem.Models
@{
    ViewData["Title"]             = "Reservations";
    ViewData["BreadcrumbCurrent"] = "Reservations";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-calendar-check me-2 text-primary"></i>Reservation Management</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Reservation
    </a>
</div>

<!-- Search -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-2">
                <label class="form-label fw-semibold">Reservation #</label>
                <input name="id" type="number" class="form-control" placeholder="ID" value="@Model.ReservationID" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">Customer NIC</label>
                <input name="nic" class="form-control" placeholder="NIC" value="@Model.CustomerNIC" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">Plate Number</label>
                <input name="plate" class="form-control" placeholder="Plate" value="@Model.PlateNumber" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">From Date</label>
                <input name="startDate" type="date" class="form-control" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">To Date</label>
                <input name="endDate" type="date" class="form-control" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1"><i class="bi bi-search me-1"></i>Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i></a>
            </div>
        </form>
    </div>
</div>

<!-- Results -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <span class="fw-semibold text-muted">@Model.Results.Count() reservation(s) found</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#ID</th>
                        <th>Customer</th>
                        <th>Vehicle</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Days</th>
                        <th>Price (LKR)</th>
                        <th>Payment</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Results)
                    {
                        <tr class="@(r.IsActive ? "" : "table-secondary opacity-75")">
                            <td><span class="fw-bold text-primary">#@r.ReservationID</span></td>
                            <td>
                                <a asp-controller="Customer" asp-action="Details" asp-route-id="@r.CustomerNIC"
                                   class="fw-semibold text-decoration-none">
                                    @(r.Customer?.Name ?? r.CustomerNIC)
                                </a>
                                <br /><small class="text-muted">@r.CustomerNIC</small>
                            </td>
                            <td>
                                <a asp-controller="Vehicle" asp-action="Details" asp-route-id="@r.PlateNumber"
                                   class="text-decoration-none">
                                    @(r.Vehicle != null ? $"{r.Vehicle.Manufacturer} {r.Vehicle.Model}" : r.PlateNumber)
                                </a>
                                <br /><small class="text-muted">@r.PlateNumber</small>
                            </td>
                            <td>@r.RentalStartDate.ToString("dd MMM yyyy")</td>
                            <td>@r.RentalEndDate.ToString("dd MMM yyyy")</td>
                            <td>@r.RentalDays</td>
                            <td class="fw-semibold">@r.Price.ToString("N0")</td>
                            <td>
                                @{
                                    var (pClass, pText) = r.PaymentStatus switch
                                    {
                                        PaymentStatus.Paid     => ("bg-success", "Paid"),
                                        PaymentStatus.Refunded => ("bg-secondary", "Refunded"),
                                        _                      => ("bg-warning text-dark", "Pending")
                                    };
                                }
                                <span class="badge @pClass">@pText</span>
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@r.ReservationID"
                                       class="btn btn-outline-info" title="Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@r.ReservationID"
                                       class="btn btn-outline-warning" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (r.IsActive)
                                    {
                                        <a asp-action="Cancel" asp-route-id="@r.ReservationID"
                                           class="btn btn-outline-danger" title="Cancel">
                                            <i class="bi bi-x-circle"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Results.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-5">
                                <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>No reservations found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
