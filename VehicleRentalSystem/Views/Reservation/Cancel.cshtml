@model VehicleRentalSystem.Models.Reservation
@{
    ViewData["Title"]             = $"Cancel Reservation #{Model.ReservationID}";
    ViewData["BreadcrumbParent"]  = "Reservations";
    ViewData["BreadcrumbCurrent"] = "Cancel";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm border-top border-danger border-3">
            <div class="card-body text-center p-5">
                <i class="bi bi-calendar-x-fill text-danger fs-1 mb-3 d-block"></i>
                <h5 class="fw-bold mb-1">Cancel Reservation #@Model.ReservationID?</h5>
                <p class="text-muted mb-4">The reservation will be marked as cancelled and payment status set to Refunded.</p>
                <div class="alert alert-light border text-start mb-4">
                    <table class="table table-sm mb-0">
                        <tr><th>Customer</th><td>@(Model.Customer?.Name ?? Model.CustomerNIC)</td></tr>
                        <tr><th>Vehicle</th><td>@Model.PlateNumber</td></tr>
                        <tr><th>Period</th><td>@Model.RentalStartDate.ToString("dd MMM") → @Model.RentalEndDate.ToString("dd MMM yyyy")</td></tr>
                        <tr><th>Price</th><td>LKR @Model.Price.ToString("N0")</td></tr>
                    </table>
                </div>
                <form asp-action="Cancel" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.ReservationID" />
                    <button type="submit" class="btn btn-danger px-4 me-2">
                        <i class="bi bi-x-circle me-1"></i>Yes, Cancel Reservation
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.ReservationID" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left me-1"></i>Go Back
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>
