@* Location/Details.cshtml *@
@model VehicleRentalSystem.Models.Location
@{
    ViewData["Title"]             = $"Location #{Model.LocationID}";
    ViewData["BreadcrumbParent"]  = "Locations";
    ViewData["BreadcrumbCurrent"] = $"#{Model.LocationID}";
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="fw-bold mb-3"><i class="bi bi-building me-2 text-primary"></i>Location #@Model.LocationID</h5>
                <table class="table table-sm">
                    <tr><th>Address</th><td>@Model.Address</td></tr>
                    <tr><th>Contact</th><td>@Model.ContactNumber</td></tr>
                    <tr><th>Vehicles</th><td><strong>@Model.Vehicles.Count</strong></td></tr>
                    <tr><th>Added</th><td>@Model.CreatedAt.ToString("dd MMM yyyy")</td></tr>
                </table>
                <div class="d-grid gap-2">
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.LocationID" class="btn btn-warning">
                            <i class="bi bi-pencil me-1"></i>Edit Location
                        </a>
                    }
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-car-front me-2 text-primary"></i>Vehicles at this Location (@Model.Vehicles.Count)
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Plate</th><th>Make/Model</th><th>Year</th><th>Daily Rate</th><th>Status</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var v in Model.Vehicles)
                            {
                                <tr>
                                    <td><a asp-controller="Vehicle" asp-action="Details" asp-route-id="@v.PlateNumber">@v.PlateNumber</a></td>
                                    <td>@v.Manufacturer @v.Model</td>
                                    <td>@v.Year</td>
                                    <td>LKR @v.DailyRate.ToString("N0")</td>
                                    <td><span class="badge bg-@(v.AvailabilityStatus == VehicleRentalSystem.Models.VehicleAvailabilityStatus.Available ? "success" : "warning text-dark")">@v.AvailabilityStatus</span></td>
                                </tr>
                            }
                            @if (!Model.Vehicles.Any())
                            {
                                <tr><td colspan="5" class="text-center text-muted py-4">No vehicles at this location.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
