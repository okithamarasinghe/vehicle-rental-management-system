@model VehicleRentalSystem.Models.Location
@{
    ViewData["Title"]             = "Delete Location";
    ViewData["BreadcrumbParent"]  = "Locations";
    ViewData["BreadcrumbCurrent"] = "Delete";
}
<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm border-top border-danger border-3">
            <div class="card-body text-center p-5">
                <i class="bi bi-geo-alt-fill text-danger fs-1 mb-3 d-block"></i>
                <h5 class="fw-bold mb-1">Delete Location #@Model.LocationID?</h5>
                <p class="text-muted mb-4">Locations with assigned vehicles cannot be deleted.</p>
                <div class="alert alert-light border text-start mb-4">
                    <table class="table table-sm mb-0">
                        <tr><th>Address</th><td>@Model.Address</td></tr>
                        <tr><th>Contact</th><td>@Model.ContactNumber</td></tr>
                        <tr><th>Vehicles</th><td>@Model.Vehicles.Count</td></tr>
                    </table>
                </div>
                <form asp-action="Delete" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.LocationID" />
                    <button type="submit" class="btn btn-danger px-4 me-2">
                        <i class="bi bi-trash me-1"></i>Yes, Delete
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-lg me-1"></i>Cancel
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>
