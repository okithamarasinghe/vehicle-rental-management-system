@* Account/UserList.cshtml *@
@model IList<(VehicleRentalSystem.Data.ApplicationUser User, IList<string> Roles)>
@{
    ViewData["Title"]             = "User Management";
    ViewData["BreadcrumbCurrent"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-shield-lock me-2 text-primary"></i>User Management</h4>
    <a asp-action="Register" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Register User
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Roles</th>
                        <th>Status</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (user, roles) in Model)
                    {
                        <tr>
                            <td class="fw-semibold">
                                <i class="bi bi-person-circle me-1 text-muted"></i>@user.FullName
                            </td>
                            <td>@user.Email</td>
                            <td>
                                @foreach (var role in roles)
                                {
                                    <span class="badge @(role == "Admin" ? "bg-danger" : "bg-info") me-1">@role</span>
                                }
                            </td>
                            <td>
                                <span class="badge @(user.IsActive ? "bg-success" : "bg-secondary")">
                                    @(user.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td><small>@user.CreatedAt.ToString("dd MMM yyyy")</small></td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">No users found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
