<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – VehicleRent Pro</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="d-flex" id="wrapper">
        <!-- ── Sidebar ──────────────────────────────────────────────── -->
        <nav id="sidebar" class="sidebar d-flex flex-column flex-shrink-0 p-3 text-white">
            <a href="/" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-white text-decoration-none">
                <i class="bi bi-car-front-fill fs-4 me-2"></i>
                <span class="fs-5 fw-bold">VehicleRent Pro</span>
            </a>
            <hr class="text-white-50" />
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index"
                       class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Vehicle" asp-action="Index"
                       class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Vehicle" ? "active" : "")">
                        <i class="bi bi-car-front me-2"></i>Vehicles
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Customer" asp-action="Index"
                       class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "active" : "")">
                        <i class="bi bi-people me-2"></i>Customers
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Reservation" asp-action="Index"
                       class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservation" ? "active" : "")">
                        <i class="bi bi-calendar-check me-2"></i>Reservations
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Location" asp-action="Index"
                       class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Location" ? "active" : "")">
                        <i class="bi bi-geo-alt me-2"></i>Locations
                    </a>
                </li>
                @if (User.IsInRole("Admin"))
                {
                    <li class="mt-3"><small class="text-white-50 text-uppercase">Admin</small></li>
                    <li class="nav-item">
                        <a asp-controller="Account" asp-action="UserList"
                           class="nav-link text-white">
                            <i class="bi bi-shield-lock me-2"></i>User Management
                        </a>
                    </li>
                }
            </ul>
            <hr class="text-white-50" />
            <div class="d-flex align-items-center text-white">
                <i class="bi bi-person-circle fs-5 me-2"></i>
                <span class="me-auto small">@User.Identity!.Name</span>
                <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-light" type="submit">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </nav>

        <!-- ── Page Content ─────────────────────────────────────────── -->
        <div id="page-content-wrapper" class="flex-grow-1">
            <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm px-4 py-2">
                <button class="btn btn-outline-secondary me-3" id="sidebarToggle">
                    <i class="bi bi-list"></i>
                </button>
                <nav aria-label="breadcrumb" class="flex-grow-1">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                        @if (ViewData["BreadcrumbParent"] is string parent)
                        {
                            <li class="breadcrumb-item active">@parent</li>
                        }
                        @if (ViewData["BreadcrumbCurrent"] is string current)
                        {
                            <li class="breadcrumb-item active">@current</li>
                        }
                    </ol>
                </nav>
            </nav>

            <div class="container-fluid p-4">
                @if (TempData["Success"] is string success)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@success
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] is string error)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-circle me-2"></i>@error
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
