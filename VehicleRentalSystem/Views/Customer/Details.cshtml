@model VehicleRentalSystem.Models.Customer
@using VehicleRentalSystem.Models
@{
    ViewData["Title"]             = $"Customer – {Model.Name}";
    ViewData["BreadcrumbParent"]  = "Customers";
    ViewData["BreadcrumbCurrent"] = Model.Name;
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center pt-4">
                <div class="customer-avatar mb-3">
                    <i class="bi bi-person-circle fs-1 text-primary"></i>
                </div>
                <h5 class="fw-bold">@Model.Name</h5>
                <span class="badge bg-secondary mb-3">@Model.NIC</span>
                <table class="table table-sm text-start">
                    <tr><th>Mobile</th><td>@Model.MobilePhoneNumber</td></tr>
                    <tr><th>Email</th><td>@(Model.Email ?? "–")</td></tr>
                    <tr><th>Address</th><td>@Model.Address</td></tr>
                    <tr><th>Member Since</th><td>@Model.CreatedAt.ToString("dd MMM yyyy")</td></tr>
                    <tr><th>Reservations</th><td><strong>@Model.Reservations.Count</strong></td></tr>
                </table>
                <div class="d-grid gap-2 mt-2">
                    <a asp-action="Edit" asp-route-id="@Model.NIC" class="btn btn-warning">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-controller="Reservation" asp-action="Create" asp-route-customerNic="@Model.NIC"
                       class="btn btn-success">
                        <i class="bi bi-calendar-plus me-1"></i>New Reservation
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-calendar-week me-2 text-primary"></i>Reservation History
                </h6>
                <span class="badge bg-primary rounded-pill">@Model.Reservations.Count</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th><th>Vehicle</th><th>Start</th><th>End</th><th>Days</th><th>Price</th><th>Payment</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Reservations.OrderByDescending(r => r.RentalStartDate))
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Reservation" asp-action="Details" asp-route-id="@r.ReservationID">
                                            #@r.ReservationID
                                        </a>
                                    </td>
                                    <td>
                                        <a asp-controller="Vehicle" asp-action="Details" asp-route-id="@r.PlateNumber">
                                            @(r.Vehicle != null ? $"{r.Vehicle.Manufacturer} {r.Vehicle.Model}" : r.PlateNumber)
                                        </a>
                                        <br /><small class="text-muted">@r.PlateNumber</small>
                                    </td>
                                    <td>@r.RentalStartDate.ToString("dd MMM yyyy")</td>
                                    <td>@r.RentalEndDate.ToString("dd MMM yyyy")</td>
                                    <td>@r.RentalDays</td>
                                    <td>LKR @r.Price.ToString("N0")</td>
                                    <td>
                                        @{
                                            var pb = r.PaymentStatus switch
                                            {
                                                PaymentStatus.Paid     => "bg-success",
                                                PaymentStatus.Refunded => "bg-secondary",
                                                _                      => "bg-warning text-dark"
                                            };
                                        }
                                        <span class="badge @pb">@r.PaymentStatus</span>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Reservations.Any())
                            {
                                <tr><td colspan="7" class="text-center text-muted py-4">No reservations found.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
