@model VehicleRentalSystem.ViewModels.CustomerSearchViewModel
@{
    ViewData["Title"]             = "Customers";
    ViewData["BreadcrumbCurrent"] = "Customers";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-people me-2 text-primary"></i>Customer Management</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Customer
    </a>
</div>

<!-- Search -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-semibold">NIC Number</label>
                <input name="nic" class="form-control" placeholder="e.g. 199012345678" value="@Model.NIC" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">Full Name</label>
                <input name="name" class="form-control" placeholder="e.g. John" value="@Model.Name" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">Mobile Number</label>
                <input name="mobile" class="form-control" placeholder="e.g. 0771234567" value="@Model.Mobile" />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1"><i class="bi bi-search me-1"></i>Search</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i></a>
            </div>
        </form>
    </div>
</div>

<!-- Results -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <span class="fw-semibold text-muted">@Model.Results.Count() customer(s) found</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>NIC</th>
                        <th>Full Name</th>
                        <th>Mobile</th>
                        <th>Email</th>
                        <th>Address</th>
                        <th>Registered</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Results)
                    {
                        <tr>
                            <td><span class="badge bg-secondary fs-6">@c.NIC</span></td>
                            <td class="fw-semibold">@c.Name</td>
                            <td>@c.MobilePhoneNumber</td>
                            <td><small class="text-muted">@(c.Email ?? "–")</small></td>
                            <td><small>@(c.Address.Length > 35 ? c.Address[..35] + "…" : c.Address)</small></td>
                            <td><small>@c.CreatedAt.ToString("dd MMM yyyy")</small></td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@c.NIC" class="btn btn-outline-info" title="Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@c.NIC" class="btn btn-outline-warning" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-controller="Reservation" asp-action="Create" asp-route-customerNic="@c.NIC"
                                       class="btn btn-outline-success" title="New Reservation">
                                        <i class="bi bi-calendar-plus"></i>
                                    </a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Delete" asp-route-id="@c.NIC" class="btn btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Results.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                <i class="bi bi-people fs-1 d-block mb-2"></i>No customers found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
